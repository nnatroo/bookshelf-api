{
  "name": "bookshelf-api",
  "version": "1.0.0",
  "private": true,
  "description": "RESTful CRUD API for managing a personal book collection",
  "main": "app.js",
  "scripts": {
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "seed": "node ./seeds/seed.js",
    "seed:fresh": "node ./seeds/seed.js --fresh",
    "seed:clear": "node ./seeds/seed.js --clear"
  },
  "dependencies": {
    "debug": "^4.3.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
